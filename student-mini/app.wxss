/* app.wxss */
page {
  --primary-color: #1677ff;
  --success-color: #52c41a;
  --warning-color: #faad14;
  --error-color: #ff4d4f;
  --text-color: #333333;
  --text-secondary: #666666;
  --text-placeholder: #999999;
  --bg-color: #ffffff;
  --bg-gray: #f5f5f5;
  --border-color: #eeeeee;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text-color);
  background-color: var(--bg-color);
}

.container {
  min-height: 100vh;
  background-color: var(--bg-gray);
}

.card {
  background: var(--bg-color);
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 24rpx;
}

.btn-primary {
  background: var(--primary-color);
  color: #ffffff;
  border-radius: 8rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  text-align: center;
  border: none;
}

.btn-primary[disabled] {
  background: #cccccc;
}

.btn-secondary {
  background: var(--bg-color);
  color: var(--primary-color);
  border: 1rpx solid var(--primary-color);
  border-radius: 8rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  text-align: center;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--text-placeholder);
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
}
