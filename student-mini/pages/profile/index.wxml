<!-- pages/profile/index.wxml -->
<view class="container">
  <!-- 用户信息 -->
  <view class="profile-header">
    <image class="avatar" src="{{userInfo.avatar || '/static/images/avatar.png'}}" mode="aspectFill" />
    <view class="user-info">
      <text class="user-name">{{userInfo.name || '未登录'}}</text>
      <text class="user-id" wx:if="{{userInfo.studentId}}">学号：{{userInfo.studentId}}</text>
    </view>
  </view>
  
  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goToMyApply">
      <text class="menu-icon">📋</text>
      <text class="menu-name">我的申请</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToMyTickets">
      <text class="menu-icon">🎫</text>
      <text class="menu-name">我的工单</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToFeedback">
      <text class="menu-icon">💬</text>
      <text class="menu-name">意见反馈</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToFeedbackHistory">
      <text class="menu-icon">📜</text>
      <text class="menu-name">反馈记录</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
  
  <!-- 设置 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goToSettings">
      <text class="menu-icon">⚙️</text>
      <text class="menu-name">设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-name">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
  
  <!-- 退出按钮 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>
</view>
