/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.welcome-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: #ffffff;
}

.welcome-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.welcome-date {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.message-btn {
  position: relative;
  padding: 16rpx;
}

.message-icon {
  font-size: 40rpx;
}

.message-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #ff4d4f;
  color: #ffffff;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.banner {
  height: 300rpx;
  margin: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner image {
  width: 100%;
  height: 100%;
}

.shortcuts {
  display: flex;
  justify-content: space-around;
  padding: 32rpx;
  background: #ffffff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.shortcut-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.shortcut-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.shortcut-name {
  font-size: 24rpx;
  color: #666;
}

.entry-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.entry-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.entry-icon {
  font-size: 48rpx;
}

.entry-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.news-section {
  background: #ffffff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

.news-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.news-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.news-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.news-title {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.news-time {
  font-size: 24rpx;
  color: #999;
  margin-left: 24rpx;
  flex-shrink: 0;
}
