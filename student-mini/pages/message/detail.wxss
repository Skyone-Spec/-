/* pages/message/detail.wxss */
.container {
  min-height: 100vh;
  background: #ffffff;
  padding-bottom: 48rpx;
}

.detail-header {
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.5;
  display: block;
}

.detail-meta {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.detail-time {
  font-size: 24rpx;
  color: #999;
}

.detail-source {
  font-size: 24rpx;
  color: #999;
  margin-left: 24rpx;
  padding-left: 24rpx;
  border-left: 1rpx solid #ddd;
}

.detail-body {
  padding: 32rpx;
}

.detail-text {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
}

.detail-attachments {
  padding: 32rpx;
  background: #f8f8f8;
  margin: 0 32rpx;
  border-radius: 12rpx;
}

.attachment-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.attachment-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 8rpx;
  margin-top: 16rpx;
}

.attachment-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.attachment-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}
