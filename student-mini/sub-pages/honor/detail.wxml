<view class="page">
  <view wx:if="{{detail && !loading}}">
    <view class="detail-hero">
      <view class="hero-tags">
        <text class="year-tag">{{detail.awardYear}}</text>
        <text class="type-tag">{{detail.typeText}}</text>
      </view>
      <text class="detail-title">{{detail.displayTitle}}</text>
      <text class="detail-desc">{{detail.description || '点击下方获奖者查看获奖简介、先进事迹、照片等内容。'}}</text>
      <view class="hero-stat">
        <text class="stat-number">{{detail.recipientCount}}</text>
        <text class="stat-label">公开获奖者</text>
      </view>
    </view>

    <view class="section-head">
      <text class="section-title">获得者展示</text>
      <text class="section-count">{{detail.countText}}</text>
    </view>

    <view class="recipient-list">
      <view
        wx:for="{{recipients}}"
        wx:key="id"
        class="recipient-card"
        bindtap="goToRecipient"
        data-id="{{item.id}}"
      >
        <view class="avatar">{{item.initial}}</view>
        <view class="recipient-main">
          <text class="recipient-name">{{item.recipientName}}</text>
          <text wx:if="{{item.meta}}" class="recipient-meta">{{item.meta}}</text>
          <text class="recipient-intro">{{item.intro}}</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>

    <view wx:if="{{recipients.length === 0}}" class="empty-state">暂无公开获得者</view>
  </view>

  <view wx:if="{{loading}}" class="loading-state">加载中...</view>
</view>
