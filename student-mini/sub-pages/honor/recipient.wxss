.page {
  min-height: 100vh;
  background: #f4f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.profile-card,
.content-card {
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 12rpx 30rpx rgba(21, 42, 72, 0.06);
}

.profile-card {
  min-height: 180rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: linear-gradient(135deg, #ffffff 0%, #edf6ff 100%);
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.profile-main {
  min-width: 0;
}

.name,
.meta {
  display: block;
}

.name {
  color: #172235;
  font-size: 40rpx;
  font-weight: 800;
}

.meta {
  margin-top: 12rpx;
  color: #66768d;
  font-size: 26rpx;
  line-height: 1.45;
}

.content-card {
  margin-top: 22rpx;
  padding: 28rpx;
}

.section-title {
  color: #172235;
  font-size: 31rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.body-text {
  display: block;
  color: #3b4b62;
  font-size: 28rpx;
  line-height: 1.8;
  white-space: pre-wrap;
}

.member-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.member-item {
  padding: 20rpx;
  border-radius: 14rpx;
  background: #f5f8fc;
}

.member-name,
.member-meta {
  display: block;
}

.member-name {
  color: #172235;
  font-size: 28rpx;
  font-weight: 700;
}

.member-meta {
  margin-top: 8rpx;
  color: #728197;
  font-size: 24rpx;
}

.attachment-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.attachment-item {
  min-width: 0;
}

.attachment-item image,
.file-tile {
  width: 100%;
  height: 210rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #edf3fb;
}

.file-tile {
  color: #1677ff;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.attachment-name {
  display: block;
  margin-top: 10rpx;
  color: #58677d;
  font-size: 24rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.loading-state {
  color: #8a98aa;
  font-size: 26rpx;
  text-align: center;
  padding: 160rpx 0;
}
