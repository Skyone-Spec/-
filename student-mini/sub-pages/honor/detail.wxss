.page {
  min-height: 100vh;
  background: #f4f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.detail-hero {
  border-radius: 16rpx;
  padding: 34rpx;
  background: linear-gradient(135deg, #145fe5 0%, #1788ff 62%, #1bb7b2 100%);
  color: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(22, 119, 255, 0.22);
}

.hero-tags {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.year-tag,
.type-tag {
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
}

.year-tag {
  background: #ffffff;
  color: #1677ff;
  font-weight: 700;
}

.type-tag {
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
}

.detail-title {
  display: block;
  margin-top: 24rpx;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.35;
}

.detail-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.65;
  opacity: 0.92;
}

.hero-stat {
  margin-top: 28rpx;
  width: 190rpx;
  height: 96rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.16);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.stat-number {
  font-size: 36rpx;
  font-weight: 800;
}

.stat-label {
  margin-top: 4rpx;
  font-size: 22rpx;
  opacity: 0.84;
}

.section-head {
  margin: 34rpx 6rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  color: #172235;
  font-size: 32rpx;
  font-weight: 700;
}

.section-count {
  color: #7c8ba1;
  font-size: 24rpx;
}

.recipient-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.recipient-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 12rpx 30rpx rgba(21, 42, 72, 0.06);
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: #eaf3ff;
  color: #1677ff;
  font-size: 34rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.recipient-main {
  flex: 1;
  min-width: 0;
}

.recipient-name,
.recipient-meta,
.recipient-intro {
  display: block;
}

.recipient-name {
  color: #172235;
  font-size: 31rpx;
  font-weight: 700;
}

.recipient-meta {
  margin-top: 8rpx;
  color: #7c8ba1;
  font-size: 24rpx;
}

.recipient-intro {
  margin-top: 10rpx;
  color: #55657c;
  font-size: 25rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.arrow {
  color: #a1acba;
  font-size: 44rpx;
  flex-shrink: 0;
}

.empty-state,
.loading-state {
  color: #8a98aa;
  font-size: 26rpx;
  text-align: center;
  padding: 120rpx 0;
}
