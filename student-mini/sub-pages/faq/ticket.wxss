/* sub-pages/faq/ticket.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.ticket-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.ticket-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.ticket-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.ticket-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}

.status-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.status-replied {
  background: #f6ffed;
  color: #52c41a;
}

.status-closed {
  background: #f5f5f5;
  color: #999;
}

.ticket-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.ticket-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ticket-time {
  font-size: 24rpx;
  color: #999;
}

.ticket-reply {
  font-size: 24rpx;
  color: #1677ff;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading-more {
  text-align: center;
  padding: 32rpx;
  color: #999;
  font-size: 24rpx;
}
