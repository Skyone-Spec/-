/* sub-pages/faq/list.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.list {
  padding: 24rpx;
}

.faq-item {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.faq-question {
  display: flex;
  align-items: center;
  padding: 32rpx;
}

.faq-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.faq-title {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.faq-arrow {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

.faq-answer {
  display: flex;
  padding: 0 32rpx 32rpx 64rpx;
}

.faq-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 30rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.loading-more {
  text-align: center;
  padding: 32rpx;
  color: #999;
  font-size: 24rpx;
}
