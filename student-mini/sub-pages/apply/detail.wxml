<!-- sub-pages/apply/detail.wxml -->
<view class="container">
  <view wx:if="{{detail && !loading}}">
    <!-- 基本信息 -->
    <view class="info-card">
      <view class="info-header">
        <text class="info-type">{{detail.typeName}}</text>
        <text class="info-status status-{{detail.status}}">{{detail.statusText}}</text>
      </view>
      
      <view class="info-item">
        <text class="info-label">申请用途</text>
        <text class="info-value">{{detail.purpose || '未填写'}}</text>
      </view>
      
      <view class="info-item" wx:if="{{detail.remark}}">
        <text class="info-label">备注</text>
        <text class="info-value">{{detail.remark}}</text>
      </view>
      
      <view class="info-item">
        <text class="info-label">申请时间</text>
        <text class="info-value">{{detail.createTime}}</text>
      </view>
    </view>
    
    <!-- 审批进度 -->
    <view class="progress-card" wx:if="{{detail.approvals && detail.approvals.length > 0}}">
      <view class="progress-title">审批进度</view>
      
      <view class="approval-list">
        <view 
          wx:for="{{detail.approvals}}"
          wx:key="id"
          class="approval-item"
        >
          <view class="approval-line"></view>
          <view class="approval-dot {{item.status}}"></view>
          <view class="approval-content">
            <view class="approval-header">
              <text class="approval-name">{{item.approverName}}</text>
              <text class="approval-time">{{item.time}}</text>
            </view>
            <text class="approval-result {{item.status}}">{{item.resultText}}</text>
            <text class="approval-comment" wx:if="{{item.comment}}">{{item.comment}}</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 附件 -->
    <view class="attachment-card" wx:if="{{detail.attachments && detail.attachments.length > 0}}">
      <view class="attachment-title">附件</view>
      <view 
        wx:for="{{detail.attachments}}"
        wx:key="id"
        class="attachment-item"
        bindtap="downloadFile"
        data-url="{{item.url}}"
        data-name="{{item.name}}"
      >
        <text class="attachment-icon">📎</text>
        <text class="attachment-name">{{item.name}}</text>
        <text class="attachment-download">下载</text>
      </view>
    </view>
    
    <!-- 生成的证明 -->
    <view class="file-card" wx:if="{{detail.generatedFile}}">
      <view class="file-title">生成的证明文件</view>
      <view class="file-item" bindtap="downloadFile" data-url="{{detail.generatedFile.url}}" data-name="{{detail.generatedFile.name}}">
        <text class="file-icon">📄</text>
        <text class="file-name">{{detail.generatedFile.name}}</text>
        <text class="file-download">查看</text>
      </view>
    </view>
    
    <!-- 撤回按钮 -->
    <view class="action-bar" wx:if="{{detail.canCancel}}">
      <button class="cancel-btn" bindtap="handleCancel" loading="{{canceling}}" disabled="{{canceling}}">撤回申请</button>
    </view>
  </view>
  
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>
</view>
