/* sub-pages/apply/detail.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.info-card,
.progress-card,
.attachment-card,
.file-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-type {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.info-status {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
}

.status-submitted {
  background: #fff7e6;
  color: #fa8c16;
}

.status-approved {
  background: #f6ffed;
  color: #52c41a;
}

.status-rejected {
  background: #fff2f0;
  color: #ff4d4f;
}

.status-draft {
  background: #f5f5f5;
  color: #999;
}

.info-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

/* 审批进度 */
.progress-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
}

.approval-list {
  position: relative;
}

.approval-item {
  display: flex;
  position: relative;
  padding-left: 48rpx;
  padding-bottom: 48rpx;
}

.approval-item:last-child {
  padding-bottom: 0;
}

.approval-line {
  position: absolute;
  left: 11rpx;
  top: 32rpx;
  bottom: 0;
  width: 2rpx;
  background: #e0e0e0;
}

.approval-item:last-child .approval-line {
  display: none;
}

.approval-dot {
  position: absolute;
  left: 0;
  top: 4rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 12rpx;
  background: #ccc;
}

.approval-dot.completed {
  background: #52c41a;
}

.approval-dot.processing {
  background: #1677ff;
}

.approval-dot.rejected {
  background: #ff4d4f;
}

.approval-content {
  flex: 1;
}

.approval-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.approval-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.approval-time {
  font-size: 24rpx;
  color: #999;
}

.approval-result {
  font-size: 26rpx;
  color: #666;
}

.approval-result.completed {
  color: #52c41a;
}

.approval-result.processing {
  color: #1677ff;
}

.approval-result.rejected {
  color: #ff4d4f;
}

.approval-comment {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* 附件 */
.attachment-title,
.file-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.attachment-item,
.file-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.attachment-item:last-child,
.file-item:last-child {
  margin-bottom: 0;
}

.attachment-icon,
.file-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.attachment-name,
.file-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.attachment-download,
.file-download {
  font-size: 26rpx;
  color: #1677ff;
}

/* 撤回按钮 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.cancel-btn {
  width: 100%;
  height: 88rpx;
  background: #ffffff;
  color: #ff4d4f;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: 1rpx solid #ff4d4f;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}
