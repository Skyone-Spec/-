/* sub-pages/academic/index.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 200rpx;
}

/* 学分卡片 */
.credit-card,
.module-card,
.warning-card,
.failed-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.credit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.credit-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.credit-time {
  font-size: 24rpx;
  color: #999;
}

/* 环形图 */
.credit-overview {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
}

.credit-ring {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  margin-right: 48rpx;
}

.ring-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #f0f0f0;
}

.ring-progress {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #1677ff 50%, transparent 50%);
}

.ring-center {
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  top: 20rpx;
  left: 20rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-percent {
  font-size: 40rpx;
  font-weight: 700;
  color: #1677ff;
}

.credit-info {
  display: flex;
  flex-direction: column;
}

.credit-current {
  font-size: 56rpx;
  font-weight: 700;
  color: #333;
}

.credit-sep {
  font-size: 32rpx;
  color: #999;
}

.credit-total {
  font-size: 32rpx;
  color: #999;
}

.credit-label {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 模块学分 */
.module-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.module-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.module-item {
  display: flex;
  flex-direction: column;
}

.module-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.module-name {
  font-size: 26rpx;
  color: #666;
}

.module-count {
  font-size: 26rpx;
  color: #999;
}

.module-bar {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.module-progress {
  height: 100%;
  background: #1677ff;
  border-radius: 6rpx;
}

/* 预警 */
.warning-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.warning-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.warning-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fa8c16;
}

.warning-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  padding: 8rpx 0;
}

/* 未通过 */
.failed-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ff4d4f;
  margin-bottom: 24rpx;
}

.failed-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.failed-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background: #fff5f5;
  border-radius: 8rpx;
}

.failed-name {
  font-size: 26rpx;
  color: #333;
}

.failed-score {
  font-size: 24rpx;
  color: #ff4d4f;
}

/* 操作按钮 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  background: #ffffff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.upload-btn,
.detail-btn {
  flex: 1;
  height: 88rpx;
  font-size: 30rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.upload-btn {
  background: #1677ff;
  color: #ffffff;
}

.detail-btn {
  background: #f5f5f5;
  color: #666;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin: 24rpx 0;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}
