<!-- sub-pages/academic/report.wxml -->
<view class="container">
  <view wx:if="{{report && !loading}}">
    <!-- 概览 -->
    <view class="overview-card">
      <view class="overview-gpa">
        <text class="gpa-value">{{report.gpa}}</text>
        <text class="gpa-label">当前 GPA</text>
      </view>
      <view class="overview-stats">
        <view class="stat-item">
          <text class="stat-value">{{report.credits}}</text>
          <text class="stat-label">已获学分</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{report.rank}}</text>
          <text class="stat-label">专业排名</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{report.warningCount}}</text>
          <text class="stat-label">学业预警</text>
        </view>
      </view>
    </view>
    
    <!-- 成绩分布 -->
    <view class="chart-card">
      <text class="card-title">成绩分布</text>
      <view class="grade-bars">
        <view wx:for="{{report.gradeDistribution}}" wx:key="range" class="grade-bar-item">
          <view class="bar-wrapper">
            <view class="bar-fill" style="width: {{item.percent}}%; background: {{item.color}}"></view>
          </view>
          <text class="bar-label">{{item.range}}</text>
          <text class="bar-count">{{item.count}}门</text>
        </view>
      </view>
    </view>
    
    <!-- GPA趋势 -->
    <view class="chart-card">
      <text class="card-title">GPA 趋势</text>
      <view class="gpa-trend">
        <view wx:for="{{report.gpaTrend}}" wx:key="semester" class="trend-item">
          <view class="trend-dot"></view>
          <text class="trend-semester">{{item.semester}}</text>
          <text class="trend-value">{{item.gpa}}</text>
        </view>
      </view>
    </view>
    
    <!-- 学业预警 -->
    <view class="warning-card" wx:if="{{report.warnings && report.warnings.length > 0}}">
      <text class="card-title">⚠️ 学业预警</text>
      <view wx:for="{{report.warnings}}" wx:key="id" class="warning-item">
        <text class="warning-type">{{item.type}}</text>
        <text class="warning-desc">{{item.description}}</text>
      </view>
    </view>
  </view>
  
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>
</view>
