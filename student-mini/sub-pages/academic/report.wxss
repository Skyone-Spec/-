/* sub-pages/academic/report.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

.overview-card {
  background: linear-gradient(135deg, #1677ff, #4096ff);
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
}

.overview-gpa {
  text-align: center;
  margin-bottom: 40rpx;
}

.gpa-value {
  font-size: 80rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
}

.gpa-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.overview-stats {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

.chart-card,
.warning-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

.grade-bars {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.grade-bar-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.bar-wrapper {
  flex: 1;
  height: 24rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 12rpx;
}

.bar-label {
  font-size: 24rpx;
  color: #666;
  width: 100rpx;
}

.bar-count {
  font-size: 24rpx;
  color: #999;
  width: 80rpx;
  text-align: right;
}

.gpa-trend {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 200rpx;
}

.trend-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.trend-dot {
  width: 16rpx;
  height: 16rpx;
  background: #1677ff;
  border-radius: 50%;
  margin-bottom: 16rpx;
}

.trend-semester {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.trend-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.warning-item {
  padding: 24rpx;
  background: #fff7e6;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.warning-type {
  font-size: 26rpx;
  color: #fa8c16;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.warning-desc {
  font-size: 24rpx;
  color: #666;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}
