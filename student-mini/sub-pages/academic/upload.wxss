/* sub-pages/academic/upload.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 200rpx;
}

.upload-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.upload-header {
  margin-bottom: 32rpx;
}

.upload-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.upload-tip {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* 上传区域 */
.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  background: #f8f8f8;
  border: 2rpx dashed #ddd;
  border-radius: 16rpx;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.upload-text {
  font-size: 30rpx;
  color: #1677ff;
  font-weight: 500;
}

.upload-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 文件预览 */
.preview-area {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 32rpx;
}

.file-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.file-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.file-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 24rpx;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-actions {
  display: flex;
  gap: 32rpx;
}

.action-btn {
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
}

.action-btn.view {
  color: #1677ff;
  background: #e6f0ff;
}

.action-btn.delete {
  color: #ff4d4f;
  background: #fff0f0;
}

/* 进度条 */
.progress-area {
  margin-top: 32rpx;
}

.progress-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #1677ff;
  border-radius: 8rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
  display: block;
  text-align: center;
}

/* 说明 */
.tips-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.tips-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.upload-btn {
  width: 100%;
  height: 96rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.upload-btn[disabled] {
  background: #cccccc;
}
