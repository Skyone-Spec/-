/* sub-pages/login/index.wxss */
.login-container {
  min-height: 100vh;
  background: #ffffff;
  padding: 0 48rpx;
}

.header-section {
  padding-top: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-illustration {
  width: 400rpx;
  height: 400rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #333;
  margin-top: 48rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: #999;
  margin-top: 16rpx;
}

.form-section {
  margin-top: 80rpx;
}

.form-item {
  margin-bottom: 48rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.form-input {
  height: 96rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
}

.login-btn {
  height: 96rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 64rpx;
  border: none;
}

.login-btn.locked {
  background: #cccccc;
}

.login-tips {
  text-align: center;
  margin-top: 32rpx;
  font-size: 24rpx;
  color: #999;
}

.error-tips {
  text-align: center;
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #ff4d4f;
}
