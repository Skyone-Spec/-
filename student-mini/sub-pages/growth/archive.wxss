.page {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 24rpx;
}

.hero-card {
  background: linear-gradient(135deg, #1d4ed8 0%, #60a5fa 100%);
  border-radius: 28rpx;
  padding: 32rpx;
  color: #ffffff;
  box-shadow: 0 20rpx 48rpx rgba(29, 78, 216, 0.22);
}

.hero-main {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 52rpx;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  flex-shrink: 0;
}

.hero-text {
  flex: 1;
  min-width: 0;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 600;
}

.hero-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.hero-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
  color: #ffffff;
}

.hero-desc {
  display: block;
  margin-top: 24rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.88);
}

.section-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(15, 35, 95, 0.05);
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2d3d;
}

.section-subtitle {
  font-size: 22rpx;
  color: #7a8ca5;
}

.profile-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-top: 24rpx;
}

.profile-item {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f8fbff;
  border: 1rpx solid #ebf2ff;
}

.profile-label {
  display: block;
  font-size: 22rpx;
  color: #7a8ca5;
}

.profile-value {
  display: block;
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #223355;
  line-height: 1.5;
}

.module-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-top: 24rpx;
}

.module-card {
  padding: 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7faff 100%);
  border: 1rpx solid #e9f1ff;
}

.module-top,
.overview-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.module-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #1677ff, #7c3aed);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
}

.mode-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.mode-self {
  background: #e8f3ff;
  color: #1677ff;
}

.mode-disabled {
  background: #fff2e8;
  color: #c96a17;
}

.module-title,
.overview-title {
  display: block;
  margin-top: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #223355;
}

.module-desc,
.overview-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7a8ca5;
}

.module-count,
.overview-count {
  display: block;
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #4a6fa1;
}

.overview-card {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #edf2fa;
}

.overview-card:first-of-type {
  margin-top: 0;
  padding-top: 0;
  border-top: none;
}

.overview-text {
  flex: 1;
  min-width: 0;
}

.overview-meta {
  margin-top: 18rpx;
}

.award-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.award-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f3f7ff;
  color: #4a6fa1;
  font-size: 22rpx;
}

.record-card {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f9fbff;
  border: 1rpx solid #edf3ff;
}

.record-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #223355;
}

.record-time {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8b98ad;
}

.field-row {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}

.field-label {
  width: 180rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: #7a8ca5;
}

.field-value {
  flex: 1;
  font-size: 24rpx;
  color: #334155;
  line-height: 1.6;
}

.empty-block {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #f8fbff;
  font-size: 24rpx;
  color: #94a3b8;
  text-align: center;
}

.action-row {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
}

.action-btn {
  min-width: 152rpx;
  border-radius: 999rpx;
}

.action-primary {
  background: #1677ff;
  color: #ffffff;
}
