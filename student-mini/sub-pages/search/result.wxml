<!-- sub-pages/search/result.wxml -->
<view class="container">
  <view class="search-header">
    <text class="search-keyword">"{{keyword}}"</text>
    <text class="search-count" wx:if="{{!loading}}">找到 {{results.length}} 条结果</text>
  </view>
  
  <view class="results">
    <view 
      wx:for="{{results}}"
      wx:key="id"
      class="result-item"
      bindtap="goToDetail"
      data-type="{{item.type}}"
      data-id="{{item.id}}"
    >
      <view class="result-type {{item.type}}">{{item.typeName}}</view>
      <text class="result-title">{{item.title}}</text>
      <text class="result-summary">{{item.summary}}</text>
      <text class="result-time">{{item.time}}</text>
    </view>
  </view>
  
  <view wx:if="{{empty && !loading}}" class="empty-state">
    <text class="empty-icon">🔍</text>
    <text class="empty-text">未找到相关结果</text>
    <text class="empty-hint">换个关键词试试</text>
  </view>
  
  <view wx:if="{{loading}}" class="loading-state">
    <text>搜索中...</text>
  </view>
</view>
