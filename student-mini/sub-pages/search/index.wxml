<!-- sub-pages/search/index.wxml -->
<view class="container">
  <!-- 搜索框 -->
  <view class="search-bar">
    <input 
      class="search-input" 
      type="text" 
      placeholder="搜索政策、通知、问答..."
      value="{{keyword}}"
      bindinput="onSearchInput"
      bindconfirm="handleSearch"
    />
    <button class="search-btn" bindtap="handleSearch">搜索</button>
  </view>
  
  <!-- 搜索结果区域 -->
  <view wx:if="{{hasResult}}">
    <!-- 分类Tab -->
    <view class="result-tabs">
      <view 
        wx:for="{{tabs}}" 
        wx:key="index"
        class="tab-item {{activeTab === index ? 'active' : ''}}"
        bindtap="onTabChange"
        data-index="{{index}}"
      >
        <text>{{item}}</text>
      </view>
    </view>
    
    <!-- 结果列表 -->
    <view class="result-list">
      <view 
        wx:for="{{resultList}}"
        wx:key="id"
        class="result-item"
        bindtap="goToDetail"
        data-id="{{item.id}}"
        data-type="{{item.type}}"
      >
        <view class="result-info">
          <text class="result-title">{{item.title}}</text>
          <text class="result-desc">{{item.summary}}</text>
          <view class="result-meta">
            <text class="result-type">{{item.type}}</text>
            <text class="result-time">{{item.time}}</text>
          </view>
        </view>
      </view>
      
      <view wx:if="{{resultList.length === 0 && !loading}}" class="empty-result">
        <text>未找到相关结果</text>
      </view>
    </view>
  </view>
  
  <!-- 搜索前区域 -->
  <view wx:if="{{!hasResult}}">
    <!-- 搜索历史 -->
    <view class="history-section" wx:if="{{historyList.length > 0}}">
      <view class="section-header">
        <text class="section-title">搜索历史</text>
        <text class="clear-btn" bindtap="clearHistory">清除</text>
      </view>
      <view class="tag-list">
        <view 
          wx:for="{{historyList}}"
          wx:key="index"
          class="tag-item"
          bindtap="onTagTap"
          data-keyword="{{item}}"
        >
          <text>{{item}}</text>
        </view>
      </view>
    </view>
    
    <!-- 热门搜索 -->
    <view class="hot-section">
      <view class="section-header">
        <text class="section-title">热门搜索</text>
      </view>
      <view class="tag-list">
        <view 
          wx:for="{{hotList}}"
          wx:key="index"
          class="tag-item hot"
          bindtap="onTagTap"
          data-keyword="{{item}}"
        >
          <text>{{item}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>
</view>
