/* sub-pages/party/detail.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 200rpx;
}

.header-card {
  background: linear-gradient(135deg, #c41e3a, #e63946);
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  display: block;
}

.header-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 16rpx;
  display: block;
}

.content-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.content-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.content-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.content-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.content-item {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.process-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.process-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.process-num {
  width: 48rpx;
  height: 48rpx;
  background: #c41e3a;
  color: #ffffff;
  font-size: 24rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.process-text {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  padding-top: 10rpx;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.apply-btn {
  width: 100%;
  height: 96rpx;
  background: #c41e3a;
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 48rpx;
  border: none;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}
