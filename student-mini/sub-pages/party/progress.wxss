/* sub-pages/party/progress.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 200rpx;
}

.header-card {
  background: linear-gradient(135deg, #c41e3a, #e63946);
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  display: block;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 12rpx;
  display: block;
}

.stage-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.stage-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.stage-label {
  font-size: 28rpx;
  color: #666;
}

.stage-status {
  font-size: 28rpx;
  color: #c41e3a;
  font-weight: 600;
}

.stage-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #c41e3a, #e63946);
  border-radius: 6rpx;
}

.progress-text {
  font-size: 26rpx;
  color: #c41e3a;
  font-weight: 600;
  min-width: 80rpx;
  text-align: right;
}

.timeline-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.timeline-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
}

.timeline {
  position: relative;
}

.timeline-item {
  display: flex;
  position: relative;
  padding-left: 48rpx;
  padding-bottom: 48rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: 0;
  top: 4rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 12rpx;
  background: #ddd;
  z-index: 1;
}

.timeline-item.completed .timeline-dot {
  background: #c41e3a;
}

.timeline-item.processing .timeline-dot {
  background: #c41e3a;
  box-shadow: 0 0 0 8rpx rgba(196, 30, 58, 0.2);
}

.timeline-line {
  position: absolute;
  left: 11rpx;
  top: 32rpx;
  bottom: 0;
  width: 2rpx;
  background: #e0e0e0;
}

.timeline-item:last-child .timeline-line {
  display: none;
}

.timeline-item.completed .timeline-line {
  background: #c41e3a;
}

.timeline-content {
  flex: 1;
}

.timeline-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.timeline-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.timeline-time {
  font-size: 24rpx;
  color: #999;
}

.timeline-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  display: block;
  margin-bottom: 8rpx;
}

.timeline-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  background: #f5f5f5;
  color: #999;
}

.timeline-status.completed {
  background: #fff2f0;
  color: #c41e3a;
}

.timeline-status.processing {
  background: #fff7e6;
  color: #fa8c16;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.apply-btn {
  width: 100%;
  height: 96rpx;
  background: #c41e3a;
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}
