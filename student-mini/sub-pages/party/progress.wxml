<!-- sub-pages/party/progress.wxml -->
<view class="container">
  <view wx:if="{{detail && !loading}}">
    <!-- 标题 -->
    <view class="header-card">
      <text class="header-title">{{detail.title}}</text>
      <text class="header-subtitle">{{detail.subtitle}}</text>
    </view>
    
    <!-- 当前阶段 -->
    <view class="stage-card">
      <view class="stage-header">
        <text class="stage-label">当前阶段</text>
        <text class="stage-status">{{detail.currentStage}}</text>
      </view>
      <view class="stage-progress">
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{detail.progressPercent}}%"></view>
        </view>
        <text class="progress-text">{{detail.progressPercent}}%</text>
      </view>
    </view>
    
    <!-- 流程时间线 -->
    <view class="timeline-card">
      <view class="timeline-title">入党流程</view>
      
      <view class="timeline">
        <view 
          wx:for="{{detail.stages}}"
          wx:key="id"
          class="timeline-item {{item.status}}"
        >
          <view class="timeline-dot"></view>
          <view class="timeline-line"></view>
          <view class="timeline-content">
            <view class="timeline-header">
              <text class="timeline-name">{{item.name}}</text>
              <text class="timeline-time" wx:if="{{item.time}}">{{item.time}}</text>
            </view>
            <text class="timeline-desc">{{item.description}}</text>
            <text class="timeline-status {{item.status}}">{{item.statusText}}</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 申请按钮 -->
    <view class="action-bar" wx:if="{{detail.canApply}}">
      <button class="apply-btn" bindtap="goToApply">申请{{detail.applyBtnText}}</button>
    </view>
  </view>
  
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>
</view>
