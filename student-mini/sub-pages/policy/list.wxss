/* sub-pages/policy/list.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* Tab */
.tabs {
  display: flex;
  background: #ffffff;
  padding: 0 32rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #1677ff;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #1677ff;
  border-radius: 3rpx;
}

/* 列表 */
.list {
  padding: 24rpx;
}

.item {
  display: flex;
  align-items: center;
  background: #ffffff;
  padding: 32rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.item-content {
  flex: 1;
}

.item-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  display: block;
}

.item-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.item-date {
  font-size: 24rpx;
  color: #999;
}

.item-tag {
  font-size: 22rpx;
  color: #1677ff;
  background: #e6f0ff;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  margin-left: 16rpx;
}

.item-tag.important {
  color: #ff4d4f;
  background: #fff0f0;
}

.item-arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 16rpx;
}

/* 模板项 */
.template-item {
  padding: 24rpx;
}

.template-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.item-format {
  font-size: 24rpx;
  color: #999;
}

.item-size {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

.download-btn {
  font-size: 26rpx;
  color: #1677ff;
  padding: 12rpx 24rpx;
  border: 1rpx solid #1677ff;
  border-radius: 8rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading-more {
  text-align: center;
  padding: 32rpx;
  color: #999;
  font-size: 24rpx;
}
