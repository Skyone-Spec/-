# 学院服务平台 - 环境变量配置

# API 基础路径
# 开发环境: http://localhost:8080/api/v1
# 生产环境: https://your-domain.com/api/v1
VITE_API_BASE_URL=/api/v1

# 启用 Mock 数据 (true/false)
VITE_ENABLE_MOCK=true

# 是否启用权限控制
VITE_ENABLE_PERMISSION=true

# 应用标题
VITE_APP_TITLE=学院学生综合服务平台

# 应用版本
VITE_APP_VERSION=1.0.0

# 是否显示调试信息
VITE_DEBUG=false

# 路由模式 (hash/history)
VITE_ROUTE_MODE=history

# 默认语言
VITE_DEFAULT_LOCALE=zh-CN

# 分页默认大小
VITE_DEFAULT_PAGE_SIZE=10

# 分页可选大小
VITE_PAGE_SIZES=10,20,50,100

# 文件上传最大大小 (MB)
VITE_MAX_FILE_SIZE=50

# 允许的文件类型
VITE_ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png

# Token 过期时间 (小时)
VITE_TOKEN_EXPIRY=24

# 是否启用日志
VITE_ENABLE_LOG=true

# 日志级别 (debug/info/warn/error)
VITE_LOG_LEVEL=info

# 演示账号配置
VITE_DEMO_ACCOUNTS=true
VITE_DEMO_USERS=[{"username":"admin","password":"123456","role":"SUPER_ADMIN"},{"username":"teacher01","password":"123456","role":"COUNSELOR"},{"username":"2023100002","password":"123456","role":"LEAGUE_SECRETARY"},{"username":"2023100001","password":"123456","role":"STUDENT"}]
